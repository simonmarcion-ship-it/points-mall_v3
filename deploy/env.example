# Copy this file to deploy/.env on the server.
# The new v3 deployment intentionally avoids the old 18081 port.

ADMIN_PORT=18082
CLIENT_PORT=18083

MALL_AUTO_IMPORT=0
MALL_SESSION_SECRET=change-this-session-secret
MALL_COOKIE_SECURE=0

# Optional: mount crawler_v2 output for admin refresh/import operations.
MALL_CRAWLER_V2_OUTPUT_DIR=../crawler_v2_output

# Optional WeChat client OAuth settings.
WECHAT_APPID=
WECHAT_APPSECRET=
WECHAT_OAUTH_REDIRECT_URI=

# Optional real SMS verification settings.
SMS_ENABLED=0
SMS_PROVIDER=aliyun_sms
ALIYUN_ACCESS_KEY_ID=
ALIYUN_ACCESS_KEY_SECRET=
ALIYUN_SMS_SIGN_NAME=
ALIYUN_SMS_TEMPLATE_CODE=
WEIWEBS_SMS_BASE_URL=https://www.weiwebs.cn/msg/HttpBatchSendSM
WEIWEBS_SMS_ACCOUNT=
WEIWEBS_SMS_PASSWORD=
WEIWEBS_SMS_SIGN_NAME=
WEIWEBS_SMS_PRODUCT=
WEIWEBS_SMS_AUTH_MODE=plain

# Optional Cargeer enrichment settings.
CARGEER_ENABLED=0
CARGEER_ACCOUNT=
CARGEER_USERNAME=
CARGEER_PASSWORD=
CARGEER_CAPTCHA_TOKEN=
JFBYM_TOKEN=
CARGEER_TIMEOUT=15
